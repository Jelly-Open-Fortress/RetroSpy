local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer

-- 1. Create the Full-Screen UI Layer
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "RadarViewportOverlay"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true 
screenGui.Parent = localPlayer:WaitForChild("PlayerGui")

-- 2. Create the Transparent Viewport
local viewportFrame = Instance.new("ViewportFrame")
viewportFrame.Size = UDim2.new(1, 0, 1, 0)
viewportFrame.BackgroundTransparency = 1 
viewportFrame.Parent = screenGui

-- 3. Setup the Dedicated Viewport Camera
local viewportCamera = Instance.new("Camera")
viewportCamera.FieldOfView = workspace.CurrentCamera.FieldOfView
viewportCamera.Parent = viewportFrame
viewportFrame.CurrentCamera = viewportCamera

-- Configuration Colors
local RED_COLOR = BrickColor.new("Bright red")       
local BLUE_COLOR = BrickColor.new("Bright blue")     
local YELLOW_COLOR = BrickColor.new("Bright yellow") 
local GREEN_COLOR = BrickColor.new("Bright green")   

-- Memory Tracking Arrays
local activeReplicas = {}
local lootHitboxReplicas = {} -- Tracks ONLY the single _main parts
local dangerousPlayers = {} 
local detectivePlayers = {} 

-- Target Identifiers
local DETECTIVE_ID_PATTERN = "82328781"
local OBFUSCATED_NAME = "\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255\255"

-- DYNAMIC LOOT FOLDER FINDER
local function findLootFolder()
	local gameFolder = workspace:FindFirstChild("Game")
	if not gameFolder then return nil end
	local lootContainer = gameFolder:FindFirstChild("Loot")
	if not lootContainer then return nil end
	
	local dropsFolder = lootContainer:FindFirstChild("drops") or lootContainer:FindFirstChild(OBFUSCATED_NAME)
	if dropsFolder then return dropsFolder end
	
	for _, child in ipairs(lootContainer:GetChildren()) do
		if child:IsA("Folder") or child:IsA("Model") then
			return child
		end
	end
	return nil
end

-- Role Scanner
local function scanPlayerForRole(player)
	local isDetective = false
	local hasRadar = false
	
	local function checkContainer(container)
		if not container then return end
		for _, item in ipairs(container:GetDescendants()) do
			if (item:IsA("SpecialMesh") or item:IsA("FileMesh")) and item.MeshId ~= "" then
				if string.find(item.MeshId, DETECTIVE_ID_PATTERN) then
					isDetective = true
				end
			end
			if item.Name == "radartool" then
				hasRadar = true
			end
		end
	end
	
	checkContainer(player:FindFirstChild("Backpack"))
	checkContainer(player.Character)
	
	if isDetective then return "Detective"
	elseif hasRadar then return "Dangerous"
	else return "None" end
end

-- Round Transition Handler
local function onNewRoundStarted()
	task.wait(1.5) 
	dangerousPlayers = {}
	detectivePlayers = {}
	
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer then
			local scanResult = scanPlayerForRole(player)
			if scanResult == "Detective" then detectivePlayers[player.UserId] = true
			elseif scanResult == "Dangerous" then dangerousPlayers[player.UserId] = true end
		end
	end
end

-- Fast Visibility Applier
local function setPartProperties(part, visible, brickColor)
	if visible then
		part.Transparency = -3 
		part.BrickColor = brickColor
		part.Material = Enum.Material.ForceField 
	else
		part.Transparency = 1 
	end
	part.CanCollide = false
	part.Anchored = true
end

local function setReplicaVisibility(model, visible, brickColor)
	for _, part in ipairs(model:GetDescendants()) do
		if part:IsA("BasePart") then
			setPartProperties(part, visible, brickColor)
		end
	end
end

-- Round Tracking Variables
local lastAliveCount = 0

----------------------------------------
-- LIGHTWEIGHT INTEGRATED RENDER LOOP
----------------------------------------
RunService.RenderStepped:Connect(function()
	local mainCamera = workspace.CurrentCamera
	if mainCamera then
		viewportCamera.CFrame = mainCamera.CFrame
		viewportCamera.FieldOfView = mainCamera.FieldOfView
	end
	
	local currentAliveCount = 0
	
	-- PHASE 1: PROCESS PLAYERS
	for _, player in ipairs(Players:GetPlayers()) do
		if player ~= localPlayer then
			local realChar = player.Character
			local realRoot = realChar and realChar:FindFirstChild("HumanoidRootPart")
			local humanoid = realChar and realChar:FindFirstChildOfClass("Humanoid")
			
			if realChar and realRoot and humanoid and humanoid.Health > 0 then
				currentAliveCount = currentAliveCount + 1
			end
			
			local replica = activeReplicas[player.UserId]
			if not replica then
				replica = Instance.new("Model")
				replica.Name = player.Name .. "_Replica"
				replica.Parent = viewportFrame
				activeReplicas[player.UserId] = replica
			end
			
			if realChar and realRoot and humanoid and humanoid.Health > 0 then
				local liveCheck = scanPlayerForRole(player)
				if liveCheck == "Dangerous" then dangerousPlayers[player.UserId] = true end
				
				local targetColor = BLUE_COLOR 
				if detectivePlayers[player.UserId] then targetColor = YELLOW_COLOR 
				elseif dangerousPlayers[player.UserId] then targetColor = RED_COLOR end
				
				for _, realPart in ipairs(realChar:GetChildren()) do
					if realPart:IsA("BasePart") then
						local repPart = replica:FindFirstChild(realPart.Name)
						if not repPart then
							repPart = realPart:Clone()
							repPart:ClearAllChildren() 
							repPart.Parent = replica
						end
						repPart.CFrame = realPart.CFrame
					end
				end
				setReplicaVisibility(replica, true, targetColor)
			else
				setReplicaVisibility(replica, false)
				dangerousPlayers[player.UserId] = nil
				detectivePlayers[player.UserId] = nil
			end
		end
	end

	-- PHASE 2: HYPER-OPTIMIZED HITBOX SCANNING (CLONE ONLY _MAIN)
	local lootFolder = findLootFolder()
	local currentLootInWorkspace = {}
	
	if lootFolder then
		for _, weaponWrapper in ipairs(lootFolder:GetChildren()) do
			-- Find the absolute hitbox tracking node recursively
			local realMainHitbox = weaponWrapper:FindFirstChild("_main", true)
			
			if realMainHitbox and realMainHitbox:IsA("BasePart") then
				-- Index using the wrapper container to know when it gets picked up
				currentLootInWorkspace[weaponWrapper] = true
				
				local repHitbox = lootHitboxReplicas[weaponWrapper]
				-- Clone ONLY the isolated _main box part, ignoring all gun details
				if not repHitbox then
					repHitbox = realMainHitbox:Clone()
					repHitbox:ClearAllChildren() -- Strip scaling values, meshes, or welds
					setPartProperties(repHitbox, true, GREEN_COLOR)
					repHitbox.Parent = viewportFrame
					lootHitboxReplicas[weaponWrapper] = repHitbox
				end
				
				-- Directly position just this singular box part
				repHitbox.CFrame = realMainHitbox.CFrame
			end
		end
	end
	
	-- CLEAR HITBOX GHOSTS IMMEDIATELY WHEN THE WEAPON NO LONGER EXISTS
	for realWeapon, repHitbox in pairs(lootHitboxReplicas) do
		if not currentLootInWorkspace[realWeapon] or not realWeapon.Parent then
			repHitbox:Destroy()
			lootHitboxReplicas[realWeapon] = nil
		end
	end
	
	-- PHASE 3: ROUND MAINTENANCE
	if lastAliveCount <= 1 and currentAliveCount > 1 then
		onNewRoundStarted()
	end
	lastAliveCount = currentAliveCount
	
	for userId, replica in pairs(activeReplicas) do
		if not Players:GetPlayerByUserId(userId) then
			replica:Destroy()
			activeReplicas[userId] = nil
			dangerousPlayers[userId] = nil
			detectivePlayers[userId] = nil
		end
	end
end)
